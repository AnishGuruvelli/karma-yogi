# Shared
APP_ENV=development

# Backend
API_PORT=8080
# Production-friendly option: set this and backend will use it directly.
# Example: postgresql://user:pass@host/db?sslmode=require
DATABASE_URL=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=karma_yogi
POSTGRES_USER=karma
POSTGRES_PASSWORD=karma
POSTGRES_SSLMODE=disable
JWT_SECRET=replace-with-strong-random
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_HOURS=720
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8081/auth/google/callback
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:5173,http://localhost:5174

# Frontend
# Vite dev server uses port 8081 by default (see frontend/vite.config.ts); keep CORS and Google redirect URLs in sync.
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_GOOGLE_CLIENT_ID=replace-with-google-client-id
VITE_DEV_AUTO_LOGIN=false
VITE_CLIENT_PLATFORM=web
VITE_APP_VERSION=dev
